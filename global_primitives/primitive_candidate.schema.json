{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Primitive Candidate",
  "type": "object",
  "required": [
    "primitive_id",
    "title",
    "primitive_key",
    "primitive_type",
    "status",
    "summary",
    "mechanism",
    "epistemic_role",
    "scope_conditions",
    "non_transfer_cases",
    "required_transfer_test",
    "mutator_guidance",
    "firing_squad_attack",
    "judge_penalty_condition",
    "source_projects",
    "source_incident_ids",
    "evidence_summary",
    "tags",
    "confidence",
    "promotion_note"
  ],
  "properties": {
    "primitive_id": { "type": "string" },
    "title": { "type": "string" },
    "primitive_key": { "type": "string" },
    "primitive_type": {
      "type": "string",
      "enum": ["attack_pattern", "failure_pattern", "test_template", "causal_motif"]
    },
    "status": { "type": "string", "enum": ["candidate", "approved", "rejected", "retired"] },
    "summary": { "type": "string" },
    "mechanism": { "type": "string" },
    "epistemic_role": {
      "type": "string",
      "enum": ["heuristic", "attack_template", "test_template"]
    },
    "scope_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_transfer_cases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_transfer_test": { "type": "string" },
    "mutator_guidance": { "type": "string" },
    "firing_squad_attack": { "type": "string" },
    "judge_penalty_condition": { "type": "string" },
    "source_projects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_incident_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_summary": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "promotion_note": { "type": "string" }
  }
}
